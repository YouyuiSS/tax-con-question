# Requires:
# 1. load_module modules/ngx_http_js_module.so; in nginx.conf
# 2. /etc/nginx/njs/rate_limit_questions.js copied from deploy/nginx-rate-limit.js.example
js_import questions_limit from /etc/nginx/njs/rate_limit_questions.js;
js_shared_dict_zone zone=questions_per_minute:512k timeout=70s type=number evict;
js_shared_dict_zone zone=questions_per_hour:2M timeout=3700s type=number evict;
js_set $questions_rate_limited questions_limit.questionsRateLimit;

server {
    listen 80 default_server;
    server_name _;

    root /srv/tax-con-question/current/web;
    index index.html;

    location /api/events {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600;
        proxy_buffering off;
    }

    location = /api/questions {
        if ($questions_rate_limited = 1) {
            return 429;
        }

        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /h5/ {
        root /srv/tax-con-question/current;
        try_files $uri $uri/ /h5/index.html;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
