#!/usr/bin/env bash

set -Eeuo pipefail

APP_NAME="tax-con-question"
APP_DIR="/srv/${APP_NAME}"
SERVICE_NAME="${APP_NAME}-backend"
NODE_VERSION="${NODE_VERSION:-24.14.1}"

ARCH="$(uname -m)"
case "${ARCH}" in
  x86_64)
    NODE_ARCH="x64"
    ;;
  aarch64|arm64)
    NODE_ARCH="arm64"
    ;;
  *)
    echo "Unsupported architecture: ${ARCH}" >&2
    exit 1
    ;;
esac

echo "Updating system packages..."
dnf update -y
dnf install -y curl tar xz git

echo "Installing Nginx from the official repository..."
tee /etc/yum.repos.d/nginx.repo <<'EOF'
[nginx-stable]
name=nginx stable repo
baseurl=https://nginx.org/packages/centos/8/$basearch/
gpgcheck=1
enabled=1
gpgkey=https://nginx.org/keys/nginx_signing.key
module_hotfixes=true
EOF

dnf install -y nginx nginx-module-njs
systemctl enable --now nginx

if ! grep -qxF 'load_module modules/ngx_http_js_module.so;' /etc/nginx/nginx.conf; then
  sed -i '1iload_module modules/ngx_http_js_module.so;' /etc/nginx/nginx.conf
fi

echo "Installing Node.js ${NODE_VERSION}..."
mkdir -p /usr/local/lib/nodejs
NODE_DIST="node-v${NODE_VERSION}-linux-${NODE_ARCH}"
curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/${NODE_DIST}.tar.xz" -o "/tmp/${NODE_DIST}.tar.xz"
rm -rf "/usr/local/lib/nodejs/${NODE_DIST}"
tar -xJf "/tmp/${NODE_DIST}.tar.xz" -C /usr/local/lib/nodejs
ln -sfn "/usr/local/lib/nodejs/${NODE_DIST}/bin/node" /usr/local/bin/node
ln -sfn "/usr/local/lib/nodejs/${NODE_DIST}/bin/npm" /usr/local/bin/npm
ln -sfn "/usr/local/lib/nodejs/${NODE_DIST}/bin/npx" /usr/local/bin/npx
ln -sfn "/usr/local/lib/nodejs/${NODE_DIST}/bin/corepack" /usr/local/bin/corepack
rm -f "/tmp/${NODE_DIST}.tar.xz"

echo "Preparing deploy directories..."
mkdir -p "${APP_DIR}/releases" "${APP_DIR}/incoming" "${APP_DIR}/shared"
touch "${APP_DIR}/shared/backend.env"

echo "Writing systemd service..."
tee "/etc/systemd/system/${SERVICE_NAME}.service" <<EOF
[Unit]
Description=${APP_NAME} backend
After=network.target

[Service]
Type=simple
WorkingDirectory=${APP_DIR}/current/backend
Environment=NODE_ENV=production
EnvironmentFile=${APP_DIR}/shared/backend.env
ExecStart=/usr/local/bin/node dist/server.js
Restart=always
RestartSec=5
User=nginx
Group=nginx

[Install]
WantedBy=multi-user.target
EOF

echo "Writing Nginx config..."
mkdir -p /etc/nginx/njs
tee /etc/nginx/njs/rate_limit_questions.js <<'EOF'
const MINUTE_WINDOW_MS = 60 * 1000;
const HOUR_WINDOW_MS = 60 * MINUTE_WINDOW_MS;

function ttlUntilNextWindow(nowMs, windowMs) {
  return (windowMs - (nowMs % windowMs)) + 1000;
}

function questionsRateLimit(r) {
  if (r.method !== 'POST') {
    return '0';
  }

  const clientIp = r.remoteAddress || '';
  if (clientIp.length === 0) {
    return '0';
  }

  const nowMs = Date.now();
  const minuteKey = `${clientIp}:minute:${Math.floor(nowMs / MINUTE_WINDOW_MS)}`;
  const hourKey = `${clientIp}:hour:${Math.floor(nowMs / HOUR_WINDOW_MS)}`;

  try {
    const minuteCount = ngx.shared.questions_per_minute.incr(
      minuteKey,
      1,
      0,
      ttlUntilNextWindow(nowMs, MINUTE_WINDOW_MS),
    );
    const hourCount = ngx.shared.questions_per_hour.incr(
      hourKey,
      1,
      0,
      ttlUntilNextWindow(nowMs, HOUR_WINDOW_MS),
    );

    if (minuteCount > 3 || hourCount > 10) {
      return '1';
    }

    return '0';
  } catch (error) {
    r.error(`questionsRateLimit failed: ${error}`);
    return '0';
  }
}

export default { questionsRateLimit };
EOF

tee "/etc/nginx/conf.d/${APP_NAME}.conf" <<EOF
js_import questions_limit from /etc/nginx/njs/rate_limit_questions.js;
js_shared_dict_zone zone=questions_per_minute:512k timeout=70s type=number evict;
js_shared_dict_zone zone=questions_per_hour:2M timeout=3700s type=number evict;
js_set \$questions_rate_limited questions_limit.questionsRateLimit;

server {
    listen 80 default_server;
    server_name _;

    root ${APP_DIR}/current/web;
    index index.html;

    location /api/events {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_read_timeout 3600;
        proxy_buffering off;
    }

    location = /api/questions {
        if (\$questions_rate_limited = 1) {
            return 429;
        }

        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location /h5/ {
        root ${APP_DIR}/current;
        try_files \$uri \$uri/ /h5/index.html;
    }

    location / {
        try_files \$uri \$uri/ /index.html;
    }
}
EOF

rm -f /etc/nginx/conf.d/default.conf
nginx -t
systemctl daemon-reload
systemctl enable "${SERVICE_NAME}"
systemctl restart nginx

echo
echo "Bootstrap complete."
echo "Node version: $(node -v)"
echo "npm version: $(npm -v)"
echo "Nginx version: $(nginx -v 2>&1)"
echo
echo "Next steps:"
echo "1. Fill ${APP_DIR}/shared/backend.env"
echo "2. Open ECS security-group ports 22 and 80, plus 443 if you will add HTTPS"
echo "3. Set deploy/deploy.env on your local machine"
echo "4. Run npm run deploy:ecs locally"
