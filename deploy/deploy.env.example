# ECS SSH connection
DEPLOY_HOST=your-ecs-public-ip
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_SSH_KEY=/absolute/path/to/your-ecs-key.pem

# Where releases live on the server
DEPLOY_BASE_DIR=/srv/tax-con-question

# Optional shared backend env file on ECS.
# The deploy script will symlink it to current/backend/.env when it exists.
BACKEND_ENV_PATH=/srv/tax-con-question/shared/backend.env

# How many historical releases to keep on ECS
KEEP_RELEASES=5

# Optional restart and post-deploy hooks.
# Typical systemd example:
# DEPLOY_RESTART_COMMAND="sudo systemctl restart tax-con-question-backend"
# DEPLOY_POST_DEPLOY_COMMAND="sudo systemctl reload nginx"
DEPLOY_RESTART_COMMAND=
DEPLOY_POST_DEPLOY_COMMAND=
